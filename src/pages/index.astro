---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FourQuestions from '../components/FourQuestions.astro';
import { site } from '../config';

const meetings = await getCollection('meetings');
const resources = await getCollection('resources');
const requiredCount = resources.filter((r) => r.data.required).length;

const entryPoints = [
  {
    href: '/guide/',
    label: 'The Guide',
    desc: 'The 9-step EMS PLT cycle, with editable templates for every stage — from team norms to reassessment.',
    cta: 'Read the playbook',
  },
  {
    href: '/meetings/',
    label: 'The 18 Meetings',
    desc: 'A ready-to-run agenda for every meeting of the year, timed to 45 minutes with buffer meetings built in.',
    cta: 'See the meeting plan',
  },
  {
    href: '/resources/',
    label: 'Resources',
    desc: 'Every reproducible, organized by stage, with how and why to use each and which meetings it supports.',
    cta: 'Browse resources',
  },
];

const stats = [
  ['18', 'meetings across the year'],
  ['1', 'complete, authentic learning cycle'],
  ['4', 'critical questions'],
  [`${requiredCount}`, 'core reproducibles to start'],
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-brand-800 text-white">
    <div
      class="absolute inset-0 opacity-20"
      style="background-image: radial-gradient(circle at 18% 20%, #5c1a20 0, transparent 42%), radial-gradient(circle at 82% 0, #a83743 0, transparent 45%);"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 md:py-28">
      <p class="text-sm font-semibold uppercase tracking-wide text-accent-300">
        {site.schoolName} Professional Learning Teams
      </p>
      <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight tracking-tight md:text-5xl">
        We became educators to make sure every student learns.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-brand-100">
        That doesn't happen behind one closed door. Moving from PLC Lite to PLC
        Right is hard work — but it's the work that raises how much every student
        learns and sharpens our craft as teachers. This guide gives your team the
        how: what to do, when to do it, and the tools for each step, all year
        long. Let's do the work that matters most — for our students and for each
        other.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/guide/"
          class="rounded-lg bg-accent-500 px-5 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-accent-600"
        >
          Start with the Guide →
        </a>
        <a
          href="/meetings/"
          class="rounded-lg bg-white/10 px-5 py-3 text-sm font-semibold text-white ring-1 ring-white/40 transition-colors hover:bg-white/20"
        >
          Jump to the 18 meetings
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto grid max-w-6xl grid-cols-2 gap-6 px-4 py-8 md:grid-cols-4">
      {
        stats.map(([num, label]) => (
          <div>
            <p class="text-3xl font-bold text-brand-800">{num}</p>
            <p class="mt-1 text-sm text-slate-600">{label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- The promise / framing -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <h2 class="text-2xl font-bold text-brand-800 md:text-3xl">
          A PLC is not a meeting. It's how we work together to ensure students
          learn.
        </h2>
        <p class="mt-4 text-slate-600">
          PLT Lite is meetings, logistics, and activity-sharing. PLC Right is a
          continuous cycle: clarify what students must learn, check whether they
          learned it, respond when they don't, and extend when they already have
          — improving our own practice along the way.
        </p>
        <p class="mt-4 text-slate-600">
          Yes, it's more work. It's also the work that actually moves student
          learning — and it gets easier as it becomes how we work. So this year
          we keep it simple: complete <strong class="text-brand-800">one
          authentic learning cycle</strong> and build the habits that last.
        </p>
        <a
          href="/process/"
          class="mt-6 inline-flex items-center gap-1 font-medium text-brand-600 hover:underline"
        >
          Understand the process →
        </a>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
        <h3 class="font-semibold text-brand-800">The four critical questions</h3>
        <p class="mt-1 text-sm text-slate-600">
          They guide every meeting, assessment, and decision.
        </p>
        <div class="mt-5"><FourQuestions /></div>
      </div>
    </div>
  </section>

  <!-- Entry points -->
  <section class="bg-slate-100">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <h2 class="text-2xl font-bold text-brand-800 md:text-3xl">
        Everything your team needs, in one place
      </h2>
      <p class="mt-2 max-w-2xl text-slate-600">
        Organized and accessible — so teams spend their energy on students, not
        on hunting for what to do next.
      </p>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {
          entryPoints.map((e) => (
            <a
              href={e.href}
              class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-md"
            >
              <h3 class="text-lg font-bold text-brand-800 group-hover:text-brand-600">
                {e.label}
              </h3>
              <p class="mt-2 flex-1 text-sm text-slate-600">{e.desc}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-600">
                {e.cta}
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
                  →
                </span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div
      class="flex flex-col items-start gap-6 rounded-2xl bg-brand-800 p-8 text-white md:flex-row md:items-center md:justify-between md:p-12"
    >
      <div>
        <h2 class="text-2xl font-bold">Ready for the first meeting?</h2>
        <p class="mt-2 max-w-xl text-brand-100">
          Meeting 1 sets the purpose for the whole year. Open the agenda and
          you're ready to facilitate.
        </p>
      </div>
      <a
        href="/meetings/1/"
        class="shrink-0 rounded-lg bg-accent-500 px-5 py-3 text-sm font-semibold text-white hover:bg-accent-600"
      >
        Open Meeting 1 →
      </a>
    </div>
  </section>
</BaseLayout>
