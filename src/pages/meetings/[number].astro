---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FourQuestions from '../../components/FourQuestions.astro';

export async function getStaticPaths() {
  const meetings = await getCollection('meetings');
  const sorted = meetings.sort((a, b) => a.data.number - b.data.number);
  return sorted.map((m, i) => ({
    params: { number: String(m.data.number) },
    props: {
      meeting: m,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

const { meeting, prev, next } = Astro.props;
const { Content } = await render(meeting);
const data = meeting.data;

const resources = await getCollection('resources');
const byId = new Map(resources.map((r) => [r.id, r]));
const newResources = data.resources
  .map((id) => byId.get(id))
  .filter((r) => r !== undefined);
const revisitResources = data.revisit
  .map((id) => byId.get(id))
  .filter((r) => r !== undefined);
---

<BaseLayout title={`Meeting ${data.number}: ${data.title}`} description={data.focus}>
  <section class="bg-brand-800 text-white">
    <div class="mx-auto max-w-6xl px-4 py-10 md:py-14">
      <a
        href="/meetings/"
        class="no-print inline-flex items-center gap-1 text-sm font-medium text-brand-100 hover:text-white"
      >
        ← All 18 meetings
      </a>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <span
          class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 text-lg font-bold ring-1 ring-white/20"
        >
          {data.number}
        </span>
        <p class="text-sm font-semibold uppercase tracking-wide text-accent-300">
          Meeting {data.number} of 18
        </p>
        {
          data.buffer && (
            <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold ring-1 ring-white/20">
              Buffer / Reset meeting
            </span>
          )
        }
        {
          data.turningPoint && (
            <span class="rounded-full bg-accent-500 px-3 py-1 text-xs font-semibold text-white">
              The turning point
            </span>
          )
        }
      </div>
      <h1 class="mt-3 text-3xl font-bold tracking-tight md:text-4xl">
        {data.title}
      </h1>
      <p class="mt-3 max-w-3xl text-lg text-brand-100">{data.focus}</p>
    </div>
  </section>

  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 lg:grid-cols-3">
    <!-- Main column -->
    <div class="lg:col-span-2">
      <div class="mb-6 flex items-center justify-between gap-4">
        <h2 class="text-xl font-bold text-brand-800">Meeting plan</h2>
        <button
          type="button"
          onclick="window.print()"
          class="no-print inline-flex items-center gap-1.5 rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-100"
        >
          <span aria-hidden="true">🖨</span> Print this agenda
        </button>
      </div>
      <div class="rich-text print-full rounded-xl border border-slate-200 bg-white p-6">
        <Content />
      </div>

      <!-- Prev / next -->
      <nav
        class="no-print mt-8 flex flex-col gap-3 sm:flex-row sm:justify-between"
        aria-label="Meeting navigation"
      >
        {
          prev ? (
            <a
              href={`/meetings/${prev.data.number}/`}
              class="flex-1 rounded-lg border border-slate-200 bg-white p-4 text-sm hover:border-brand-300"
            >
              <span class="text-slate-500">← Previous</span>
              <span class="mt-1 block font-semibold text-brand-700">
                Meeting {prev.data.number}: {prev.data.title}
              </span>
            </a>
          ) : (
            <span class="flex-1" />
          )
        }
        {
          next ? (
            <a
              href={`/meetings/${next.data.number}/`}
              class="flex-1 rounded-lg border border-slate-200 bg-white p-4 text-right text-sm hover:border-brand-300"
            >
              <span class="text-slate-500">Next →</span>
              <span class="mt-1 block font-semibold text-brand-700">
                Meeting {next.data.number}: {next.data.title}
              </span>
            </a>
          ) : (
            <span class="flex-1" />
          )
        }
      </nav>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <div class="rounded-xl border border-brand-200 bg-brand-50 p-5">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-brand-700">
          Focus question
        </h3>
        <p class="mt-2 font-medium text-brand-900">{data.plcQuestion}</p>
      </div>

      {
        data.criticalQuestions.length > 0 && (
          <div class="rounded-xl border border-slate-200 bg-white p-5">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
              Critical question in focus
            </h3>
            <div class="mt-3">
              <FourQuestions highlight={data.criticalQuestions} />
            </div>
          </div>
        )
      }

      <div class="rounded-xl border border-accent-300 bg-accent-50 p-5">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-accent-600">
          Product / outcome
        </h3>
        <p class="mt-2 text-sm text-slate-800">{data.product}</p>
      </div>

      {
        (newResources.length > 0 || revisitResources.length > 0) && (
          <div class="rounded-xl border border-slate-200 bg-white p-5">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
              Reproducibles for this meeting
            </h3>
            {newResources.length > 0 && (
              <ul class="mt-3 space-y-2">
                {newResources.map((r) => (
                  <li>
                    <a
                      href={`/resources/#${r.id}`}
                      class="text-sm font-medium text-brand-700 hover:underline"
                    >
                      {r.data.title}
                    </a>
                    {r.data.bookLocation && (
                      <span class="ml-1 text-xs text-slate-500">
                        · {r.data.bookLocation}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            )}
            {revisitResources.length > 0 && (
              <div class="mt-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                  Revisit
                </p>
                <ul class="mt-2 space-y-2">
                  {revisitResources.map((r) => (
                    <li>
                      <a
                        href={`/resources/#${r.id}`}
                        class="text-sm text-slate-600 hover:text-brand-700 hover:underline"
                      >
                        {r.data.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
            <a
              href="/resources/"
              class="no-print mt-4 inline-block text-sm font-medium text-brand-600 hover:underline"
            >
              Browse all resources →
            </a>
          </div>
        )
      }
    </aside>
  </div>
</BaseLayout>
