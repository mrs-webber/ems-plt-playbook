---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import FourQuestions from '../../components/FourQuestions.astro';

const steps = (await getCollection('guide')).sort(
  (a, b) => a.data.step - b.data.step
);

const rendered = await Promise.all(
  steps.map(async (s) => ({ entry: s, Content: (await render(s)).Content }))
);
---

<BaseLayout
  title="The Guide"
  description="The EMS PLT playbook: a 9-step learning cycle with editable reproducible templates, from building team clarity to completing the cycle."
>
  <PageHeader
    eyebrow="The Playbook"
    title="Moving From PLC Lite to PLC Right"
    subtitle="The purpose of PLTs at EMS is not to hold meetings, share activities, or plan the next lesson. It is to ensure high levels of learning for all students through a continuous cycle of teacher learning, student evidence, team action, and reflection."
  />

  <div class="mx-auto max-w-6xl px-4 py-12">
    <!-- Four questions -->
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
      <h2 class="text-xl font-bold text-brand-800">
        A PLT is successful when teachers can clearly answer four questions
      </h2>
      <p class="mt-2 text-slate-600">
        These four questions should guide every PLT meeting, every assessment
        conversation, and every intervention and extension decision.
      </p>
      <div class="mt-6">
        <FourQuestions />
      </div>
    </section>

    <!-- Honest "why take this on" note -->
    <aside class="mt-8 rounded-2xl border border-brand-200 bg-brand-50 p-6 md:p-8">
      <h2 class="text-lg font-bold text-brand-800">Why take this on?</h2>
      <p class="mt-3 text-slate-700">
        Let's name it: this is more work than teaching behind a closed door, and
        it can feel like a lot at the start. But it's the work that raises how
        much every student learns — and, done together, it spreads the load, ends
        the isolation, and makes us better at the profession we chose. The steps
        below are how we get there, one manageable move at a time.
      </p>
    </aside>

    <div class="mt-12 gap-10 lg:grid lg:grid-cols-[16rem_1fr]">
      <!-- Sticky TOC -->
      <aside class="no-print hidden lg:block">
        <nav class="sticky top-24" aria-label="Guide steps">
          <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">
            The EMS PLT Cycle
          </p>
          <ol class="mt-4 space-y-1">
            {
              rendered.map(({ entry }) => (
                <li>
                  <a
                    href={`#step-${entry.data.step}`}
                    class="flex gap-2 rounded-md px-2 py-1.5 text-sm text-slate-600 hover:bg-slate-100 hover:text-brand-800"
                  >
                    <span class="font-semibold text-brand-700">
                      {entry.data.step}.
                    </span>
                    <span>{entry.data.title}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </nav>
      </aside>

      <!-- Steps -->
      <div class="space-y-12">
        {
          rendered.map(({ entry, Content }) => (
            <section id={`step-${entry.data.step}`} class="scroll-mt-24">
              <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
                <div class="flex items-start gap-4">
                  <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-800 text-lg font-bold text-white">
                    {entry.data.step}
                  </span>
                  <div>
                    <h2 class="text-2xl font-bold text-brand-800">
                      {entry.data.title}
                    </h2>
                    <p class="mt-1 text-slate-600">{entry.data.summary}</p>
                  </div>
                </div>

                {entry.data.plcQuestion && (
                  <p class="mt-4 inline-block rounded-lg bg-accent-50 px-3 py-1.5 text-sm font-semibold text-accent-600 ring-1 ring-accent-300">
                    {entry.data.plcQuestion}
                  </p>
                )}

                <div class="rich-text mt-6">
                  <Content />
                </div>
              </div>
            </section>
          ))
        }

        <!-- Closing reminder -->
        <section class="rounded-2xl bg-brand-800 p-8 text-white">
          <h2 class="text-xl font-bold">A final reminder for teams</h2>
          <p class="mt-3 text-brand-100">
            PLC is not a meeting. PLC is not a binder. PLC is not a form. PLC is
            not one more thing.
          </p>
          <p class="mt-3 text-brand-50">
            PLC is how we work together to ensure students learn, how we respond
            when they do not, how we extend when they already have, and how we
            grow as educators through evidence, action, and reflection.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/meetings/"
              class="rounded-lg bg-accent-500 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-600"
            >
              See the 18-meeting plan →
            </a>
            <a
              href="/resources/"
              class="rounded-lg bg-white/10 px-4 py-2 text-sm font-semibold text-white ring-1 ring-white/20 hover:bg-white/20"
            >
              Browse the reproducibles
            </a>
          </div>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
