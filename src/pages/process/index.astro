---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import FourQuestions from '../../components/FourQuestions.astro';

const bigIdeas = [
  {
    title: 'A focus on learning',
    body: 'The work centers on what students learn, not simply what teachers teach.',
  },
  {
    title: 'A collaborative culture',
    body: 'Teams work interdependently and take collective responsibility for every student.',
  },
  {
    title: 'A results orientation',
    body: 'Teams use evidence of student learning — not adult preference — to improve instruction.',
  },
];

const shifts = [
  ['Planning activities', 'Clarifying learning'],
  ['Sharing opinions', 'Analyzing evidence'],
  ['“My students”', '“Our students”'],
  ['Intervention as optional help', 'Intervention as a team response'],
  ['PLT as a meeting', 'PLC as the way we improve learning'],
];

const avoid = [
  'Spending the whole meeting on logistics.',
  'Planning activities without identifying learning targets.',
  'Looking at data without planning a response.',
  'Using assessments only for grades.',
  'Saying “my students” instead of “our students.”',
  'Moving on because the pacing guide says so.',
  'Treating intervention as optional.',
  'Giving extension as extra work.',
  'Admiring the problem without changing adult practice.',
];

const lookFors = [
  'Meetings are centered on student learning.',
  'Teachers bring evidence, not just opinions.',
  'Teams use common assessments.',
  'Students are grouped by specific learning needs.',
  'Intervention and extension are planned by the team.',
  'Teachers learn from one another’s results.',
  'The team can explain what changed because of the data.',
  'Students receive support regardless of which teacher they have.',
  'The work continues in cycles.',
];

const success = [
  'We selected one essential standard.',
  'We agreed on what students needed to know and do.',
  'We created clear learning targets.',
  'We defined proficiency.',
  'We created or refined a common formative assessment.',
  'We used the same evidence to analyze student learning.',
  'We identified students who needed support and students ready for extension.',
  'We responded as a team.',
  'We reassessed.',
  'We reflected on student learning and teacher practice.',
  'We know what we would improve in our next cycle.',
];
---

<BaseLayout
  title="The Process"
  description="What PLC Right really means — the three big ideas, the shift from PLT Lite to PLC Right, look-fors, what to avoid, and what success looks like by the end of the year."
>
  <PageHeader
    eyebrow="Why This Work Matters"
    title="Understanding the Process"
    subtitle="Solution Tree spends relatively little time on meetings and a great deal of time on culture. The distinction is between a school that does PLCs and a school that is a PLC — one that makes collaborative decisions based on evidence of student learning."
  />

  <div class="mx-auto max-w-6xl px-4 py-12">
    <!-- Big ideas -->
    <section>
      <h2 class="text-2xl font-bold text-brand-800">The three big ideas</h2>
      <p class="mt-3 max-w-3xl text-slate-600">
        Strip everything else away and the PLC process rests on three
        commitments. They are not about holding more meetings — they are about
        why we became teachers: making sure students actually learn, and getting
        better at our craft by doing that work together instead of alone.
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {
          bigIdeas.map((idea, i) => (
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
              <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent-500 text-sm font-bold text-white">
                {i + 1}
              </span>
              <h3 class="mt-4 font-semibold text-brand-800">{idea.title}</h3>
              <p class="mt-2 text-sm text-slate-600">{idea.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Four questions -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold text-brand-800">The four critical questions</h2>
      <p class="mt-2 max-w-3xl text-slate-600">
        These questions drive nearly everything teams do.
      </p>
      <div class="mt-6"><FourQuestions /></div>
    </section>

    <!-- Lite vs Right -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold text-brand-800">
        The shift: from PLT Lite to PLC Right
      </h2>
      <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
        <div class="grid grid-cols-2 bg-brand-800 text-white">
          <div class="px-5 py-3 font-semibold">We are moving away from…</div>
          <div class="px-5 py-3 font-semibold">…and toward</div>
        </div>
        {
          shifts.map(([from, to], i) => (
            <div
              class:list={[
                'grid grid-cols-2 text-sm',
                i % 2 === 0 ? 'bg-white' : 'bg-slate-50',
              ]}
            >
              <div class="border-t border-slate-200 px-5 py-3 text-slate-600">
                {from}
              </div>
              <div class="border-t border-l border-slate-200 px-5 py-3 font-medium text-brand-800">
                {to}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Avoid + Look-fors -->
    <section class="mt-14 grid gap-6 lg:grid-cols-2">
      <div class="rounded-2xl border border-rose-200 bg-rose-50 p-6">
        <h2 class="text-lg font-bold text-rose-800">What PLTs should avoid</h2>
        <ul class="mt-4 space-y-2">
          {
            avoid.map((item) => (
              <li class="flex gap-2 text-sm text-rose-900">
                <span aria-hidden="true" class="text-rose-400">✕</span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6">
        <h2 class="text-lg font-bold text-emerald-800">
          PLC Right look-fors
        </h2>
        <ul class="mt-4 space-y-2">
          {
            lookFors.map((item) => (
              <li class="flex gap-2 text-sm text-emerald-900">
                <span aria-hidden="true" class="text-emerald-500">✓</span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Success -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold text-brand-800">
        What success looks like by the end of the year
      </h2>
      <p class="mt-2 max-w-3xl text-slate-600">
        This year is not about perfection. It is about experiencing the full
        process once, learning where we get stuck, and building the habits that
        make PLC Right the normal way we work. By June, each PLT should be able
        to say:
      </p>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2">
        {
          success.map((item) => (
            <li class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-700 shadow-sm">
              <span
                aria-hidden="true"
                class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700"
                >✓</span
              >
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Reminder -->
    <section class="mt-14 rounded-2xl bg-brand-800 p-8 text-white">
      <h2 class="text-xl font-bold">The goal for this year</h2>
      <p class="mt-3 max-w-3xl text-brand-50">
        The goal is not to look like a perfect PLC by the end of the year. It is
        to complete one authentic cycle, learn from it, and prove to ourselves
        that the hard work shows up in what our students learn. Everything before
        <a href="/meetings/13/" class="font-semibold text-accent-300 underline"
          >Meeting 13</a
        > builds clarity; everything after it is where PLC Right really begins.
      </p>
    </section>
  </div>
</BaseLayout>
