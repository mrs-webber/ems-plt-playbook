---
import type { CollectionEntry } from 'astro:content';
import { formatMeetingDate } from '../config';

interface Props {
  meeting: CollectionEntry<'meetings'>;
}
const { meeting } = Astro.props;
const { number, title, focus, buffer, turningPoint } = meeting.data;
const date = formatMeetingDate(number);
---

<a
  href={`/meetings/${number}/`}
  class="group flex flex-col rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md"
>
  <div class="flex items-center justify-between">
    <span
      class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand-800 text-sm font-bold text-white"
    >
      {number}
    </span>
    <div class="flex gap-1.5">
      {
        buffer && (
          <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-semibold text-slate-600">
            Buffer / Reset
          </span>
        )
      }
      {
        turningPoint && (
          <span class="rounded-full bg-accent-100 px-2 py-0.5 text-[11px] font-semibold text-accent-600">
            Turning point
          </span>
        )
      }
    </div>
  </div>
  {
    date && (
      <p class="mt-3 text-xs font-semibold uppercase tracking-wide text-accent-600">
        {date}
      </p>
    )
  }
  <h3
    class="mt-1 font-semibold text-brand-800 group-hover:text-brand-600"
  >
    Meeting {number}: {title}
  </h3>
  <p class="mt-1 text-sm text-slate-600">{focus}</p>
  <span
    class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand-600"
  >
    View agenda
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
  </span>
</a>
