---
import { criticalQuestions } from '../config';
interface Props {
  /** Optionally highlight one or more questions (1–4). */
  highlight?: number[];
  compact?: boolean;
}
const { highlight = [], compact = false } = Astro.props;
---

<ol class:list={['grid gap-3', compact ? 'sm:grid-cols-2' : 'sm:grid-cols-2']}>
  {
    criticalQuestions.map((q, i) => {
      const n = i + 1;
      const on = highlight.includes(n);
      return (
        <li
          class:list={[
            'flex gap-3 rounded-xl border p-4 transition-colors',
            on
              ? 'border-accent-400 bg-accent-50 shadow-sm'
              : 'border-slate-200 bg-white',
          ]}
        >
          <span
            class:list={[
              'flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-sm font-bold',
              on ? 'bg-accent-500 text-white' : 'bg-brand-800 text-white',
            ]}
          >
            {n}
          </span>
          <span class="text-sm font-medium text-slate-800">{q}</span>
        </li>
      );
    })
  }
</ol>
