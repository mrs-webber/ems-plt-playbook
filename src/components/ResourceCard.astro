---
import type { CollectionEntry } from 'astro:content';

interface Props {
  resource: CollectionEntry<'resources'>;
  /** Meeting numbers where this resource is used. */
  usedIn?: number[];
}
const { resource, usedIn = [] } = Astro.props;
const { title, source, required, url, linkLabel, book, bookLocation, description, howToUse } =
  resource.data;

const sourceStyles: Record<string, string> = {
  'Solution Tree': 'bg-brand-50 text-brand-700 ring-brand-200',
  AllThingsPLC: 'bg-emerald-50 text-emerald-700 ring-emerald-200',
  'EMS-created': 'bg-accent-50 text-accent-600 ring-accent-300',
};
const external = url.startsWith('http');
---

<article
  class="flex h-full flex-col rounded-xl border border-slate-200 bg-white p-5 shadow-sm"
  id={resource.id}
>
  <div class="flex flex-wrap items-center gap-2">
    <span
      class:list={[
        'rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1 ring-inset',
        sourceStyles[source],
      ]}
    >
      {source}
    </span>
    {
      required && (
        <span class="rounded-full bg-brand-800 px-2.5 py-0.5 text-xs font-semibold text-white">
          Required packet
        </span>
      )
    }
  </div>

  <h3 class="mt-3 font-semibold text-brand-800">{title}</h3>
  <p class="mt-2 text-sm text-slate-600">{description}</p>

  <p class="mt-3 text-sm text-slate-700">
    <span class="font-semibold text-slate-900">How we'll use it:</span>
    {howToUse}
  </p>

  {
    usedIn.length > 0 && (
      <p class="mt-3 flex flex-wrap items-center gap-1.5 text-xs text-slate-500">
        <span class="font-semibold text-slate-600">Used in:</span>
        {usedIn.map((n) => (
          <a
            href={`/meetings/${n}/`}
            aria-label={`Used in Meeting ${n}`}
            class="inline-flex min-h-6 items-center rounded bg-slate-100 px-2 py-1 font-medium text-slate-700 hover:bg-brand-100 hover:text-brand-700"
          >
            M{n}
          </a>
        ))}
      </p>
    )
  }

  <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-2">
    <a
      href={url}
      target={external ? '_blank' : undefined}
      rel={external ? 'noopener noreferrer' : undefined}
      aria-label={`${linkLabel}: ${title}${external ? ' (opens in a new tab)' : ''}`}
      class="inline-flex w-fit items-center gap-1.5 rounded-lg border border-brand-200 bg-brand-50 px-3 py-1.5 text-sm font-medium text-brand-700 transition-colors hover:bg-brand-100"
    >
      {linkLabel}
      <span aria-hidden="true">{external ? '↗' : '→'}</span>
    </a>
    {
      book && (
        <p class="flex items-center gap-1.5 text-xs text-slate-500">
          <span aria-hidden="true">📖</span>
          <span>
            <span class="font-medium text-slate-700">{book}</span>
            {bookLocation && <span> · {bookLocation}</span>}
          </span>
        </p>
      )
    }
  </div>
</article>
