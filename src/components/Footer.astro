---
import { site, nav } from '../config';
---

<footer class="no-print mt-20 border-t border-slate-200 bg-white">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="flex flex-col gap-8 md:flex-row md:justify-between">
      <div class="max-w-sm">
        <p class="font-bold text-brand-800">{site.shortName}</p>
        <p class="mt-2 text-sm text-slate-600">{site.description}</p>
      </div>

      <nav aria-label="Footer">
        <p class="text-sm font-semibold text-slate-900">Explore</p>
        <ul class="mt-3 space-y-2">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-slate-600 hover:text-brand-700 hover:underline"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="max-w-xs text-sm text-slate-600">
        <p class="font-semibold text-slate-900">A note on reproducibles</p>
        <p class="mt-3">
          Official tools live on Solution Tree's Free Resources and AllThingsPLC.
          EMS-created templates are editable equivalents inspired by the PLC at
          Work process — not copies of copyrighted forms.
        </p>
      </div>
    </div>

    <div
      class="mt-8 flex flex-col gap-2 border-t border-slate-100 pt-6 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>{site.schoolName} · {site.districtName} Guiding Coalition</p>
      <p>Built as a resource for our Professional Learning Teams.</p>
    </div>
  </div>
</footer>
